{
  "name": "telegram-bot-router",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --port 8788",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "wrangler": "^4.83.0"
  },
  "cloudflare": {
    "bindings": {
      "TELEGRAM_BOT_TOKEN": {
        "description": "Your Telegram Bot Token (from @BotFather)."
      },
      "TELEGRAM_ALLOWED_USER_ID": {
        "description": "The numeric Chat ID of the authorized admin user (from @userinfobot)."
      },
      "BACKEND": {
        "description": "Service binding to the tax-payment-backend."
      }
    }
  }
}
