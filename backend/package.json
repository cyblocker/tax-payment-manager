{
  "name": "tax-payment-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply tax-payment-manager-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply tax-payment-manager-db --remote"
  },
  "dependencies": {
    "@google/genai": "^1.50.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.83.0"
  },
  "cloudflare": {
    "bindings": {
      "GEMINI_API_KEY": {
        "description": "Your Google Gemini AI API Key (from Google AI Studio)."
      },
      "DB": {
        "description": "D1 Database for storing tax bill records."
      },
      "BUCKET": {
        "description": "R2 Bucket for storing pdfs and images."
      }
    }
  }
}